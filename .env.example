# --- Tandem (bulk + live pump events via tconnectsync) -----------------
TCONNECT_EMAIL=you@example.com
TCONNECT_PASSWORD=changeme

# Optional: Tandem region. Most US users leave this unset.
# TCONNECT_REGION=US

# Date range for Tandem ingestion (ISO 8601, local interpretation handled in code).
# If unset, defaults to the last 30 days ending today.
TANDEM_START_DATE=2026-03-25
TANDEM_END_DATE=2026-04-24

# --- Dexcom Share (live CGM polling, ~5 min latency) -------------------
# Use a *follower* account, not the patient's primary login.
# Set up: Dexcom mobile app -> Share -> invite a follower -> create that
# follower's Dexcom account -> use those credentials here.
DEXCOM_USERNAME=
DEXCOM_PASSWORD=
# 'us', 'ous' (rest of world), or 'jp'.
DEXCOM_REGION=us

# Default output directory for processed parquet files
DATA_DIR=./data/processed
